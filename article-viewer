<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loading… | Sixers Hoops</title>
    <meta name="description" content="Sixers Hoops editorial coverage — player grades, analysis, previews and more.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/navbar-styles.css">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8046070602394287" crossorigin="anonymous"></script>

    <style>
        :root {
            --navy: #001a57; --navy-deep: #000d2e;
            --sixers-blue: #006BB6; --sixers-red: #ED174C;
            --cream: #f5f0e8; --ink: #0d0d0d; --mid: #4a4a5a;
            --border-light: #e8e4dc; --card-bg: #ffffff;
        }
        *, *::before, *::after { box-sizing: border-box; }
        body, html { font-family: 'Barlow', sans-serif; margin-top: 64px; background: var(--cream); color: var(--ink); }

        /* ── HERO ── */
        .article-hero {
            background: var(--navy-deep);
            padding: 3rem 1.5rem 2.5rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .article-hero::before {
            content:'';position:absolute;inset:0;
            background-image:linear-gradient(rgba(0,107,182,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(0,107,182,0.05) 1px,transparent 1px);
            background-size:48px 48px;pointer-events:none;
        }
        .article-hero-inner { max-width:760px;margin:0 auto;position:relative;z-index:1; }
        .article-tag-badge {
            display:inline-block;font-family:'Barlow Condensed',sans-serif;
            font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;
            padding:3px 10px;border-radius:4px;margin-bottom:1rem;
        }
        .article-headline {
            font-family:'Barlow Condensed',sans-serif;
            font-size:clamp(2rem,5vw,3.2rem);font-weight:900;line-height:1.05;
            color:rgba(255,255,255,0.95);margin:0 0 1rem;text-transform:uppercase;letter-spacing:-0.01em;
        }
        .article-byline { font-size:0.8rem;color:rgba(255,255,255,0.35);display:flex;align-items:center;justify-content:center;gap:0.75rem;flex-wrap:wrap; }

        /* ── BODY ── */
        .article-wrap { max-width:760px;margin:2.5rem auto;padding:0 1.5rem; }
        .back-link { display:inline-flex;align-items:center;gap:0.4rem;font-family:'Barlow Condensed',sans-serif;font-size:0.8rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--sixers-blue);text-decoration:none;margin-bottom:2rem; }
        .back-link:hover { opacity:0.75; }

        .article-body p { font-size:1rem;line-height:1.8;color:var(--ink);margin:0 0 1.4rem; }
        .article-body h2 { font-family:'Barlow Condensed',sans-serif;font-size:1.5rem;font-weight:800;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink);margin:2.5rem 0 0.75rem;padding-left:0.75rem;border-left:3px solid var(--sixers-red); }

        /* ── GRADE CARD ── */
        .grade-card { background:var(--card-bg);border:1px solid var(--border-light);border-radius:14px;padding:1.25rem 1.4rem;margin:1.25rem 0;display:flex;flex-direction:column;gap:0.6rem; }
        .grade-card-header { display:flex;align-items:center;justify-content:space-between;gap:1rem; }
        .grade-card-name { font-family:'Barlow Condensed',sans-serif;font-size:1.3rem;font-weight:900;text-transform:uppercase;color:var(--ink); }
        .grade-badge { font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;font-weight:900;color:white;padding:4px 14px;border-radius:8px;flex-shrink:0; }
        .grade-card-stats { font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--mid);padding-bottom:0.6rem;border-bottom:1px dashed var(--border-light); }
        .grade-card-analysis { font-size:0.92rem;line-height:1.65;color:#475569; }

        /* ── SKELETON ── */
        @keyframes sk { 0%,100%{opacity:1}50%{opacity:0.45} }
        .sk-line { background:#e2e8f0;border-radius:4px;animation:sk 1.4s ease-in-out infinite; }

        /* ── FOOTER ── */
        footer { background:var(--navy-deep);color:rgba(255,255,255,0.5);font-size:0.8rem;padding:2rem 1.5rem;text-align:center;margin-top:4rem; }
        footer a { color:rgba(255,255,255,0.6);text-decoration:none;margin:0 0.75rem; }
        footer a:hover { color:white; }

        /* ── DARK MODE ── */
        :root.dark-mode { --cream:#111318;--ink:#f0f0f5;--mid:#8888a0;--border-light:#1e2130;--card-bg:#171b26; }
        :root.dark-mode body { background:var(--cream);color:var(--ink); }
        :root.dark-mode .grade-card { background:var(--card-bg);border-color:var(--border-light); }
        :root.dark-mode .grade-card-name { color:var(--ink); }
        :root.dark-mode .grade-card-analysis { color:var(--mid); }
        :root.dark-mode .article-body p { color:var(--ink); }
    </style>
</head>
<body>

<!-- Skeleton hero while loading -->
<div class="article-hero" id="article-hero">
    <div class="article-hero-inner">
        <div class="sk-line" style="width:80px;height:20px;margin:0 auto 1rem;border-radius:10px;"></div>
        <div class="sk-line" style="width:80%;height:40px;margin:0 auto 0.75rem;"></div>
        <div class="sk-line" style="width:50%;height:40px;margin:0 auto 1.25rem;"></div>
        <div class="sk-line" style="width:220px;height:14px;margin:0 auto;border-radius:10px;"></div>
    </div>
</div>

<div class="article-wrap">
    <a href="/" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Back to Sixers Hoops
    </a>
    <div class="article-body" id="article-body">
        <!-- skeleton lines -->
        <div class="sk-line" style="width:100%;height:14px;margin-bottom:10px;"></div>
        <div class="sk-line" style="width:90%;height:14px;margin-bottom:10px;"></div>
        <div class="sk-line" style="width:95%;height:14px;margin-bottom:10px;"></div>
        <div class="sk-line" style="width:70%;height:14px;margin-bottom:32px;"></div>
        <div class="grade-card" style="opacity:0.4;">
            <div class="grade-card-header">
                <div class="sk-line" style="width:160px;height:22px;"></div>
                <div class="sk-line" style="width:50px;height:28px;border-radius:8px;"></div>
            </div>
            <div class="sk-line" style="width:100%;height:12px;"></div>
            <div class="sk-line" style="width:100%;height:12px;"></div>
            <div class="sk-line" style="width:80%;height:12px;"></div>
        </div>
    </div>
</div>

<footer>
    <div style="margin-bottom:0.75rem;">
        <a href="/">Home</a><a href="/about.html">About</a>
        <a href="/contact.html">Contact</a><a href="/privacy-policy.html">Privacy Policy</a>
        <a href="/terms-of-service.html">Terms of Service</a>
    </div>
    <p style="margin:0;">&copy; 2025 Sixers Hoops. Not affiliated with the Philadelphia 76ers or the NBA.</p>
</footer>

<script src="/nav.js"></script>
<script>
const GRADE_COLORS = {
    'A+':'#1a6b3c','A':'#1e7d46','A−':'#2d8f56',
    'B+':'#006BB6','B':'#0077cc','B−':'#2a85d0',
    'C+':'#b06b00','C':'#c27800',
    'D+':'#b83232','D':'#a02828','F':'#7a1a1a'
};
const CATEGORY_COLORS = {
    'Player Grades':'#1e7d46','Analysis':'#006BB6','Opinion':'#b06b00',
    'Preview':'#ED174C','Recap':'#475569','News':'#0077cc'
};

function renderArticle(a) {
    // ── Hero
    const color = CATEGORY_COLORS[a.category] || '#006BB6';
    const gradient = a.gradient || 'linear-gradient(135deg,rgba(0,107,182,0.4) 0%,rgba(237,23,76,0.2) 100%)';
    const date = a.createdAt ? (a.createdAt.toDate ? a.createdAt.toDate() : new Date(a.createdAt)).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) : '';

    document.getElementById('article-hero').style.background = '';
    document.getElementById('article-hero').innerHTML = `
        <div style="position:absolute;inset:0;background:${gradient};pointer-events:none;"></div>
        <div style="position:absolute;inset:0;background:var(--navy-deep);opacity:0.6;pointer-events:none;"></div>
        <div class="article-hero-inner">
            <div class="article-tag-badge" style="background:${color}22;color:${color};border:1px solid ${color}44;">${a.category}</div>
            <h1 class="article-headline">${a.title}</h1>
            <div class="article-byline">
                <span>Sixers Hoops Staff</span>
                <span>·</span>
                <span>${date}</span>
                ${(a.grades||[]).length > 0 ? `<span>·</span><span>${a.grades.length} players graded</span>` : ''}
            </div>
        </div>
    `;

    // ── Page title
    document.title = `${a.title} | Sixers Hoops`;

    // ── Body
    let html = '';

    if (a.intro) {
        html += `<p>${a.intro}</p>`;
    }

    if (a.grades && a.grades.length > 0) {
        // Group by position header if > 3 players
        html += `<h2>Player Grades</h2>`;
        a.grades.forEach(g => {
            const gradeColor = GRADE_COLORS[g.grade] || '#475569';
            html += `
            <div class="grade-card">
                <div class="grade-card-header">
                    <span class="grade-card-name">${g.name}</span>
                    <span class="grade-badge" style="background:${gradeColor};">${g.grade}</span>
                </div>
                ${g.stats ? `<div class="grade-card-stats">${g.stats}</div>` : ''}
                ${g.analysis ? `<div class="grade-card-analysis">${g.analysis}</div>` : ''}
            </div>`;
        });
    }

    if (a.closing) {
        html += `<h2>Bottom Line</h2><p>${a.closing}</p>`;
    }

    document.getElementById('article-body').innerHTML = html || '<p>Article content coming soon.</p>';
}

function loadArticle(tries = 0) {
    const params = new URLSearchParams(window.location.search);
    const id = params.get('id');

    if (!id) {
        document.getElementById('article-body').innerHTML = '<p>No article found. <a href="/">Go back home →</a></p>';
        return;
    }

    if (!window.db) {
        if (tries < 40) setTimeout(() => loadArticle(tries + 1), 250);
        return;
    }

    window.db.collection('editorial_articles').doc(id).get().then(doc => {
        if (!doc.exists) {
            document.getElementById('article-body').innerHTML = '<p>This article was not found or may have been removed. <a href="/">Go back home →</a></p>';
            return;
        }
        renderArticle({ id: doc.id, ...doc.data() });
    }).catch(err => {
        console.error(err);
        document.getElementById('article-body').innerHTML = '<p>Error loading article. Please try again. <a href="/">Go back home →</a></p>';
    });
}

document.addEventListener('DOMContentLoaded', () => loadArticle());
</script>

</body>
</html>

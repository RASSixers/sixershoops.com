        <div class="card">
            <div class="card-header">
                <span class="card-title">Sixers Pick History</span>
                <span class="badge badge-blue" id="history-count-badge">0 draws</span>
            </div>
            <div class="card-body" style="padding-top:0.75rem;">
                <div id="history-list">
                    <div style="text-align:center;padding:1.5rem 0;color:var(--mid);font-size:0.8rem;">
                        Run a simulation to see results here.

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Draft Lottery Simulator – Sixers Hoops</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="navbar-styles.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        border: "hsl(214.3 31.8% 91.4%)",
                        background: "hsl(0 0% 100%)",
                        foreground: "hsl(222.2 84% 4.9%)",
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --navy: #001a57;
            --navy-deep: #000d2e;
            --sixers-blue: #006BB6;
            --sixers-red: #ED174C;
            --cream: #f5f0e8;
            --ink: #0d0d0d;
            --mid: #4a4a5a;
            --border-light: #e8e4dc;
            --card-bg: #ffffff;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body, html {
            font-family: 'Barlow', sans-serif;
            margin-top: 64px;
            background: var(--cream);
            color: var(--ink);
        }

        /* ─── HERO ──────────────────────────────────── */
        .hero {
            background: var(--navy-deep);
            position: relative;
            overflow: hidden;
            padding: 0;
        }

        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(0,107,182,0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0,107,182,0.05) 1px, transparent 1px);
            background-size: 48px 48px;
            pointer-events: none;
            z-index: 0;
        }

        .hero-glow-blue {
            position: absolute;
            left: 50%; top: -80px;
            transform: translateX(-50%);
            width: 800px; height: 500px;
            background: radial-gradient(ellipse at center, rgba(0,107,182,0.2) 0%, transparent 65%);
            pointer-events: none; z-index: 0;
        }

        .hero-glow-red {
            position: absolute;
            left: 50%; bottom: -40px;
            transform: translateX(-50%);
            width: 500px; height: 300px;
            background: radial-gradient(ellipse at center, rgba(237,23,76,0.1) 0%, transparent 65%);
            pointer-events: none; z-index: 0;
        }

        .hero-inner {
            position: relative; z-index: 1;
            max-width: 860px;
            margin: 0 auto;
            padding: 4rem 2rem 2.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 0;
        }

        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(0,107,182,0.15);
            border: 1px solid rgba(0,107,182,0.3);
            border-radius: 999px;
            padding: 4px 14px 4px 8px;
            margin-bottom: 1.4rem;
        }

        .hero-eyebrow-dot {
            width: 7px; height: 7px;
            border-radius: 50%;
            background: var(--sixers-red);
            animation: pulse-dot 2s ease-in-out infinite;
        }

        @keyframes pulse-dot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(0.8); }
        }

        .hero-eyebrow-text {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
        }

        .hero-title-top {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 900;
            line-height: 0.85;
            letter-spacing: -0.01em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.95);
            margin: 0;
        }

        .hero-title-bottom {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 900;
            line-height: 0.85;
            letter-spacing: -0.01em;
            text-transform: uppercase;
            background: linear-gradient(90deg, var(--sixers-blue), #4da8ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin: 0 0 0.15em;
        }

        .hero-divider {
            width: 40px; height: 3px;
            background: var(--sixers-red);
            border-radius: 2px;
            margin: 1.1rem auto 1rem;
        }

        .hero-sub {
            font-family: 'Barlow', sans-serif;
            font-size: 0.95rem;
            font-weight: 400;
            color: rgba(255,255,255,0.38);
            max-width: 420px;
            line-height: 1.65;
            margin: 0;
        }

        /* Feature cards strip */
        .feature-cards-section {
            position: relative; z-index: 1;
            background: var(--navy-deep);
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        .feature-cards-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1px;
            background: rgba(255,255,255,0.06);
            overflow: hidden;
        }

        .feature-card {
            background: rgba(0,13,46,0.8);
            padding: 1.4rem;
            text-decoration: none;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
            position: relative;
            overflow: hidden;
            transition: background 0.25s ease;
        }

        .feature-card::before {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 2px;
            background: var(--sixers-blue);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s ease;
        }

        .feature-card:hover::before { transform: scaleX(1); }
        .feature-card:hover { background: rgba(0,107,182,0.09); }

        .feature-card-icon {
            width: 34px; height: 34px;
            border-radius: 8px;
            background: rgba(0,107,182,0.18);
            border: 1px solid rgba(0,107,182,0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #4da8ff;
            flex-shrink: 0;
        }

        .feature-card-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.9rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.82);
        }

        .feature-card-desc {
            font-size: 0.72rem;
            color: rgba(255,255,255,0.28);
            line-height: 1.5;
        }

        /* ─── MAIN LAYOUT ──────────────────────────── */
        .main-layout {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 1.5rem;
            align-items: start;
        }

        .section-label {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            font-size: 0.65rem;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--mid);
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin-bottom: 1rem;
        }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border-light);
        }

        /* ─── CARD ──────────────────────────────────── */
        .card {
            background: white;
            border: 1px solid var(--border-light);
            border-radius: 12px;
            overflow: hidden;
        }

        .card-header {
            padding: 1.25rem 1.5rem 1rem;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            font-size: 1.1rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--ink);
        }

        .card-body { padding: 1.25rem 1.5rem; }

        /* ─── STATUS BADGE ──────────────────────────── */
        .badge {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 2px 8px;
            border-radius: 4px;
        }

        .badge-blue { background: rgba(0,107,182,0.1); color: var(--sixers-blue); border: 1px solid rgba(0,107,182,0.2); }
        .badge-red { background: rgba(237,23,76,0.1); color: var(--sixers-red); border: 1px solid rgba(237,23,76,0.2); }
        .badge-green { background: rgba(16,185,129,0.1); color: #059669; border: 1px solid rgba(16,185,129,0.2); }

        /* ─── LOTTERY TABLE ─────────────────────────── */
        .lottery-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.82rem;
        }

        .lottery-table th {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.62rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--mid);
            padding: 0.5rem 0.75rem;
            text-align: left;
            background: #f9f7f3;
            border-bottom: 1px solid var(--border-light);
        }

        .lottery-table td {
            padding: 0.65rem 0.75rem;
            border-bottom: 1px solid #f0ede6;
            vertical-align: middle;
        }

        .lottery-table tr:last-child td { border-bottom: none; }

        .lottery-table tr:hover td { background: #faf8f5; }

        .lottery-table tr.highlight-row td {
            background: rgba(0,107,182,0.05) !important;
        }

        .lottery-table tr.highlight-row td:first-child {
            border-left: 3px solid var(--sixers-blue);
        }

        .team-name-cell {
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .team-rank-num {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--mid);
            width: 18px;
            text-align: center;
            flex-shrink: 0;
        }

        .team-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .pct-bar-wrap {
            width: 60px;
            height: 4px;
            background: #e8e4dc;
            border-radius: 2px;
            overflow: hidden;
            display: inline-block;
            vertical-align: middle;
            margin-right: 6px;
        }

        .pct-bar-fill {
            height: 100%;
            border-radius: 2px;
            background: var(--sixers-blue);
            transition: width 0.5s ease;
        }

        .pct-val {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.78rem;
            font-weight: 700;
            color: var(--ink);
        }

        /* ─── RUN BUTTON ────────────────────────────── */
        .btn-run {
            width: 100%;
            padding: 0.9rem 1.5rem;
            background: var(--sixers-blue);
            color: white;
            border: none;
            border-radius: 10px;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-run:hover { background: #0080d4; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,107,182,0.3); }
        .btn-run:active { transform: translateY(0); }
        .btn-run:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

        .btn-secondary {
            padding: 0.65rem 1.25rem;
            background: white;
            color: var(--mid);
            border: 1px solid var(--border-light);
            border-radius: 8px;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.82rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-secondary:hover { border-color: var(--sixers-blue); color: var(--sixers-blue); background: rgba(0,107,182,0.04); }

        /* ─── RESULTS ───────────────────────────────── */
        .result-picks {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .result-pick {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            background: #f9f7f3;
            border: 1px solid var(--border-light);
            border-radius: 10px;
            transition: all 0.3s;
            opacity: 0;
            transform: translateY(8px);
        }

        .result-pick.revealed {
            opacity: 1;
            transform: translateY(0);
        }

        .result-pick.sixers-pick {
            background: rgba(0,107,182,0.06);
            border-color: rgba(0,107,182,0.25);
        }

        .pick-num {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1.4rem;
            font-weight: 900;
            color: var(--navy);
            width: 40px;
            text-align: center;
            flex-shrink: 0;
            line-height: 1;
        }

        .pick-num.top-pick { color: var(--sixers-blue); }

        .pick-team {
            flex: 1;
        }

        .pick-team-name {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            color: var(--ink);
        }

        .pick-team-odds {
            font-size: 0.7rem;
            color: var(--mid);
            margin-top: 1px;
        }

        .pick-sixers-tag {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.55rem;
            font-weight: 800;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            background: var(--sixers-blue);
            color: white;
            padding: 2px 7px;
            border-radius: 4px;
        }

        /* ─── SPIN ANIMATION ────────────────────────── */
        @keyframes ball-spin {
            0% { transform: rotate(0deg) translateX(30px) rotate(0deg); opacity: 1; }
            100% { transform: rotate(360deg) translateX(30px) rotate(-360deg); opacity: 0; }
        }

        @keyframes fadeSlideIn {
            from { opacity: 0; transform: translateY(6px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .spinner-wrap {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            gap: 1rem;
        }

        .lottery-drum {
            width: 80px; height: 80px;
            border-radius: 50%;
            border: 3px solid var(--sixers-blue);
            position: relative;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .lottery-drum::before {
            content: '🏀';
            font-size: 2rem;
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            animation: spin 0.8s linear infinite reverse;
        }

        .spinner-text {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--mid);
            font-size: 0.85rem;
        }

        /* ─── ODDS INFO ─────────────────────────────── */
        .odds-explainer {
            background: rgba(0,107,182,0.04);
            border: 1px solid rgba(0,107,182,0.12);
            border-radius: 10px;
            padding: 1rem 1.25rem;
            font-size: 0.78rem;
            color: var(--mid);
            line-height: 1.6;
        }

        .odds-explainer strong {
            color: var(--ink);
            font-weight: 600;
        }

        /* ─── HISTORY ───────────────────────────────── */
        .history-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.6rem 0;
            border-bottom: 1px solid #f0ede6;
            font-size: 0.8rem;
        }

        .history-item:last-child { border-bottom: none; }

        .history-pick-num {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            font-size: 1rem;
            color: var(--navy);
            width: 30px;
        }

        .history-pick-num.top { color: var(--sixers-blue); }

        /* ─── LOADING STATE ─────────────────────────── */
        .loading-pulse {
            height: 18px;
            background: linear-gradient(90deg, #e8e4dc 25%, #f0ede6 50%, #e8e4dc 75%);
            background-size: 200% 100%;
            animation: shimmer 1.4s infinite;
            border-radius: 4px;
        }

        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }

        /* ─── SIMCOUNT ──────────────────────────────── */
        .sim-count-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .sim-stat-box {
            background: #f9f7f3;
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 0.75rem 1rem;
            text-align: center;
        }

        .sim-stat-val {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1.6rem;
            font-weight: 900;
            color: var(--sixers-blue);
            line-height: 1;
        }

        .sim-stat-val.red { color: var(--sixers-red); }

        .sim-stat-label {
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--mid);
            margin-top: 2px;
        }

        /* ─── RESPONSIVE ────────────────────────────── */
        @media (max-width: 768px) {
            .main-layout {
                grid-template-columns: 1fr;
                padding: 1rem;
            }

            .feature-cards-inner {
                grid-template-columns: repeat(3, 1fr);
            }

            .hero-inner { padding: 2.5rem 1.25rem 2rem; }
        }

        @media (max-width: 500px) {
            .feature-cards-inner {
                grid-template-columns: 1fr;
            }
        }

        /* Confetti */
        .confetti-piece {
            position: fixed;
            width: 10px; height: 10px;
            top: -10px;
            animation: confetti-fall linear forwards;
            z-index: 9999;
            pointer-events: none;
        }

        @keyframes confetti-fall {
            0%   { transform: translateY(0) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
        }
    </style>


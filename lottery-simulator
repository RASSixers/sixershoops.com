<script src="nav.js"></script>

<script>
// ─── NBA Lottery Odds (official 2024-25 structure) ──────────────────────────
// Mapped by rank among lottery teams (1 = worst record)
const OFFICIAL_LOTTERY_ODDS = {
    1:  { combinations: 140, pct1: 14.0 },
    2:  { combinations: 140, pct1: 14.0 },
    3:  { combinations: 140, pct1: 14.0 },
    4:  { combinations: 125, pct1: 12.5 },
    5:  { combinations: 105, pct1: 10.5 },
    6:  { combinations:  90, pct1:  9.0 },
    7:  { combinations:  75, pct1:  7.5 },
    8:  { combinations:  60, pct1:  6.0 },
    9:  { combinations:  45, pct1:  4.5 },
    10: { combinations:  30, pct1:  3.0 },
    11: { combinations:  20, pct1:  2.0 },
    12: { combinations:  15, pct1:  1.5 },
    13: { combinations:  10, pct1:  1.0 },
    14: { combinations:   5, pct1:  0.5 },
};

// Team colors for dots
const TEAM_COLORS = {
    'PHI': '#006BB6', 'BKN': '#000000', 'WAS': '#002B5C',
    'DET': '#C8102E', 'CHA': '#1D1160', 'TOR': '#CE1141',
    'SAS': '#C4CED4', 'MEM': '#5D76A9', 'POR': '#E03A3E',
    'HOU': '#CE1141', 'UTA': '#002B5C', 'OKC': '#007AC1',
    'ORL': '#0077C0', 'IND': '#FDBB30', 'ATL': '#E03A3E',
    'CHI': '#CE1141', 'NOP': '#0C2340', 'MIN': '#0C2340',
    'MIL': '#00471B', 'NYK': '#006BB6', 'LAC': '#C8102E',
    'MIA': '#98002E', 'GSW': '#1D428A', 'DEN': '#0E2240',
    'LAL': '#552583', 'PHX': '#1D1160', 'SAC': '#5A2D81',
    'DAL': '#00538C', 'CLE': '#860038', 'BOS': '#007A33',
};

let lotteryTeams = [];
let simHistory = [];
let totalDraws = 0;
let sixersTopFourCount = 0;
let sixersPick1Count = 0;
let massSimData = {};

// ─── FETCH STANDINGS AND BUILD LOTTERY ────────────────────────────────────
async function fetchAndBuildLottery() {
    const url = 'https://site.api.espn.com/apis/v2/sports/basketball/nba/standings';
    try {
        const res = await fetch(url);
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();

        const allTeams = [];
        (data.children || []).forEach(conf => {
            (conf.standings?.entries || []).forEach(entry => {
                const stats = {};
                entry.stats.forEach(s => { if (s.name) stats[s.name] = s; });
                const wins = parseInt(stats.wins?.value ?? 0);
                const losses = parseInt(stats.losses?.value ?? 0);
                allTeams.push({
                    abbr: entry.team.abbreviation,
                    name: entry.team.displayName,
                    shortName: entry.team.shortDisplayName || entry.team.displayName,
                    wins,
                    losses,
                    winPct: stats.winPercent?.value ?? 0,
                });
            });
        });

        // Sort by win pct ascending (worst first) — find bottom 14
        allTeams.sort((a, b) => a.winPct - b.winPct || b.losses - a.losses);
        lotteryTeams = allTeams.slice(0, 14).map((t, i) => ({
            ...t,
            lotteryRank: i + 1,
            combinations: OFFICIAL_LOTTERY_ODDS[i + 1].combinations,
            oddsTop1: OFFICIAL_LOTTERY_ODDS[i + 1].pct1,
        }));

        renderOddsTable();
        renderSixersOddsPanel();

        const now = new Date();
        document.getElementById('odds-updated-badge').textContent =
            `Updated ${now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`;

    } catch (err) {
        console.error('Standings Error:', err);
        document.getElementById('odds-updated-badge').textContent = 'Error';
        document.getElementById('odds-table-wrap').innerHTML = `
            <div style="padding:1.5rem;text-align:center;color:var(--sixers-red);font-size:0.85rem;">
                Failed to load standings. <button onclick="fetchAndBuildLottery()" style="color:var(--sixers-blue);background:none;border:none;cursor:pointer;font-weight:700;text-decoration:underline;">Retry</button>
            </div>`;
    }
}

function renderOddsTable() {
    const sixersRank = lotteryTeams.findIndex(t => t.abbr === 'PHI');
    let rows = lotteryTeams.map((t, i) => {
        const isSixers = t.abbr === 'PHI';
        const color = TEAM_COLORS[t.abbr] || '#888';
        const oddsTop4 = computeTop4Odds(i);
        return `
            <tr class="${isSixers ? 'highlight-row' : ''}">
                <td>
                    <div class="team-name-cell">
                        <span class="team-rank-num">${t.lotteryRank}</span>
                        <span class="team-dot" style="background:${color}"></span>
                        <span style="font-weight:${isSixers ? '700' : '500'}">${t.shortName}${isSixers ? ' ★' : ''}</span>
                    </div>
                </td>
                <td style="color:var(--mid);font-size:0.78rem;">${t.wins}-${t.losses}</td>
                <td>
                    <span class="pct-bar-wrap"><span class="pct-bar-fill" style="width:${(t.oddsTop1 / 14) * 100}%;background:${isSixers ? 'var(--sixers-blue)' : color};opacity:0.7;"></span></span>
                    <span class="pct-val">${t.oddsTop1.toFixed(1)}%</span>
                </td>
                <td><span class="pct-val" style="color:var(--mid)">${oddsTop4.toFixed(1)}%</span></td>
            </tr>`;
    }).join('');

    document.getElementById('odds-table-wrap').innerHTML = `
        <table class="lottery-table">
            <thead>
                <tr>
                    <th>Team</th>
                    <th>Record</th>
                    <th>Pick #1 Odds</th>
                    <th>Top 4 Odds</th>
                </tr>
            </thead>
            <tbody>${rows}</tbody>
        </table>`;
}

function renderSixersOddsPanel() {
    const sixers = lotteryTeams.find(t => t.abbr === 'PHI');
    if (!sixers) {
        document.getElementById('sixers-odds-display').innerHTML = `
            <div style="color:var(--mid);font-size:0.85rem;">Sixers not in lottery this year.</div>`;
        return;
    }
    const top4 = computeTop4Odds(sixers.lotteryRank - 1);
    document.getElementById('sixers-odds-display').innerHTML = `
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--mid);margin-bottom:0.3rem;">Pick #1 Odds</div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:2.8rem;font-weight:900;color:var(--sixers-blue);line-height:1;">${sixers.oddsTop1.toFixed(1)}%</div>
        <div style="margin-top:0.6rem;font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--mid);">Top 4 Odds</div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:2rem;font-weight:900;color:var(--navy);line-height:1;">${top4.toFixed(1)}%</div>
        <div style="margin-top:0.5rem;font-size:0.72rem;color:var(--mid);">Lottery Rank: #${sixers.lotteryRank} · ${sixers.wins}-${sixers.losses}</div>`;
}

// ─── LOTTERY SIMULATION ENGINE ─────────────────────────────────────────────
function runLotterySimOnce() {
    if (lotteryTeams.length === 0) return null;

    // Build ball pool: 1000 total combinations assigned per rank
    const pool = [];
    lotteryTeams.forEach((t, i) => {
        for (let j = 0; j < t.combinations; j++) pool.push(i);
    });

    const results = []; // indices into lotteryTeams for picks 1-4
    const usedTeamIndices = new Set();
    const remainingPool = [...pool];

    for (let pick = 0; pick < 4; pick++) {
        let drawn;
        let attempts = 0;
        do {
            const ballIdx = Math.floor(Math.random() * remainingPool.length);
            drawn = remainingPool[ballIdx];
            attempts++;
            if (attempts > 10000) break; // safety
        } while (usedTeamIndices.has(drawn));

        usedTeamIndices.add(drawn);
        results.push(drawn);
    }

    // Picks 5-14: remaining teams in reverse lottery rank order (worst remaining first)
    const remainingTeams = lotteryTeams
        .map((_, i) => i)
        .filter(i => !usedTeamIndices.has(i));
    // Sort by lotteryRank ascending (worst = rank 1 gets pick 5)
    remainingTeams.sort((a, b) => lotteryTeams[a].lotteryRank - lotteryTeams[b].lotteryRank);
    remainingTeams.forEach(i => results.push(i));

    return results.map((teamIdx, pickIdx) => ({
        pick: pickIdx + 1,
        team: lotteryTeams[teamIdx],
    }));
}

// Approximate top-4 odds using simulation (fast estimate)
function computeTop4Odds(rankIndex) {
    // Quick closed-form approximation based on combinations
    const t = lotteryTeams[rankIndex];
    if (!t) return 0;
    // Each team's top-4 probability is roughly their share of combinations * 4 draws
    // More accurate: use the inclusion-exclusion approximation
    const totalCombinations = 1000;
    const myCombs = t.combinations;
    let prob = 0;
    // P(top4) = 1 - P(miss all 4 draws)
    // P(miss draw 1) = 1 - myCombs/total
    // But draws are without replacement by team, so we approximate
    prob = 1 - Math.pow((totalCombinations - myCombs) / totalCombinations, 4);
    // Scale: multiply by ~1.25 for 4 draws (rough correction)
    return Math.min(prob * 100 * 1.1, 99);
}

async function runLottery() {
    if (lotteryTeams.length === 0) { alert('Standings still loading…'); return; }

    const runBtn = document.getElementById('run-btn');
    const resultsCard = document.getElementById('results-card');
    const spinnerWrap = document.getElementById('spinner-wrap');
    const resultPicksEl = document.getElementById('result-picks');

    runBtn.disabled = true;
    resultsCard.style.display = 'block';
    spinnerWrap.style.display = 'flex';
    resultPicksEl.innerHTML = '';

    await sleep(900);

    const picks = runLotterySimOnce();
    if (!picks) { runBtn.disabled = false; return; }

    spinnerWrap.style.display = 'none';

    // Find Sixers pick
    const sixersPick = picks.find(p => p.team.abbr === 'PHI');
    if (sixersPick) {
        totalDraws++;
        const pickNum = sixersPick.pick;
        if (pickNum <= 4) sixersTopFourCount++;
        if (pickNum === 1) sixersPick1Count++;
        addHistory(pickNum);
        updateHistoryBadge();

        const badge = document.getElementById('result-sixers-badge');
        badge.style.display = 'inline-block';
        badge.textContent = `Sixers → Pick #${pickNum}`;
        badge.className = `badge ${pickNum === 1 ? 'badge-green' : pickNum <= 4 ? 'badge-blue' : 'badge-red'}`;

        if (pickNum <= 4) fireConfetti();
    }

    // Render picks with stagger
    const top4 = picks.slice(0, 4);
    const rest = picks.slice(4);

    for (let i = 0; i < top4.length; i++) {
        await sleep(180);
        appendPickEl(top4[i], resultPicksEl, true);
    }

    if (rest.length > 0) {
        const restLabel = document.createElement('div');
        restLabel.style.cssText = 'font-family:\'Barlow Condensed\',sans-serif;font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--mid);margin:0.75rem 0 0.4rem;';
        restLabel.textContent = 'Picks 5–14 (by record)';
        resultPicksEl.appendChild(restLabel);

        for (let i = 0; i < rest.length; i++) {
            await sleep(40);
            appendPickEl(rest[i], resultPicksEl, false);
        }
    }

    runBtn.disabled = false;
    document.getElementById('reset-btn').style.display = '';
}

function appendPickEl(pickObj, container, isLottery) {
    const isSixers = pickObj.team.abbr === 'PHI';
    const color = TEAM_COLORS[pickObj.team.abbr] || '#888';
    const el = document.createElement('div');
    el.className = `result-pick${isSixers ? ' sixers-pick' : ''}`;
    el.innerHTML = `
        <div class="pick-num${pickObj.pick <= 4 ? ' top-pick' : ''}">${pickObj.pick}</div>
        <span class="team-dot" style="background:${color};width:10px;height:10px;border-radius:50%;flex-shrink:0;"></span>
        <div class="pick-team">
            <div class="pick-team-name">${pickObj.team.shortName}</div>
            <div class="pick-team-odds">${pickObj.pick <= 4 ? pickObj.team.oddsTop1.toFixed(1) + '% pick #1 odds' : pickObj.team.wins + '-' + pickObj.team.losses}</div>
        </div>
        ${isSixers ? '<span class="pick-sixers-tag">Sixers</span>' : ''}`;
    container.appendChild(el);
    requestAnimationFrame(() => el.classList.add('revealed'));
}

function resetSim() {
    document.getElementById('results-card').style.display = 'none';
    document.getElementById('result-picks').innerHTML = '';
    document.getElementById('result-sixers-badge').style.display = 'none';
    document.getElementById('reset-btn').style.display = 'none';
}

// ─── MASS SIMULATION ────────────────────────────────────────────────────────
async function runMassSimulation(n) {
    if (lotteryTeams.length === 0) { alert('Standings still loading…'); return; }

    const btn = document.getElementById('sim-1000-btn');
    btn.disabled = true;
    btn.textContent = 'Simulating…';

    await sleep(50);

    const pickCounts = {};
    lotteryTeams.forEach((_, i) => { for (let p = 1; p <= 14; p++) { const k = `${i}_${p}`; pickCounts[k] = 0; } });

    for (let s = 0; s < n; s++) {
        const picks = runLotterySimOnce();
        picks.forEach(({ pick, team }) => {
            lotteryTeams.forEach((t, i) => {
                if (t.abbr === team.abbr) pickCounts[`${i}_${pick}`] = (pickCounts[`${i}_${pick}`] || 0) + 1;
            });
        });
    }

    const sixersIdx = lotteryTeams.findIndex(t => t.abbr === 'PHI');
    const massCard = document.getElementById('mass-results-card');
    const simN = document.getElementById('mass-sim-n');
    const badge = document.getElementById('mass-sim-badge');
    const statsGrid = document.getElementById('sim-stats-grid');
    const tableWrap = document.getElementById('mass-result-table-wrap');

    simN.textContent = n.toLocaleString();
    badge.textContent = n.toLocaleString() + ' sims';
    badge.className = 'badge badge-blue';

    if (sixersIdx >= 0) {
        let top1 = 0, top4 = 0;
        for (let p = 1; p <= 14; p++) {
            const c = pickCounts[`${sixersIdx}_${p}`] || 0;
            if (p === 1) top1 = c;
            if (p <= 4) top4 += c;
        }
        statsGrid.innerHTML = `
            <div class="sim-stat-box">
                <div class="sim-stat-val">${((top1 / n) * 100).toFixed(1)}%</div>
                <div class="sim-stat-label">Got #1 Pick</div>
            </div>
            <div class="sim-stat-box">
                <div class="sim-stat-val">${((top4 / n) * 100).toFixed(1)}%</div>
                <div class="sim-stat-label">Top 4 Pick</div>
            </div>`;

        // Pick distribution table
        let distRows = '';
        for (let p = 1; p <= lotteryTeams.length; p++) {
            const c = pickCounts[`${sixersIdx}_${p}`] || 0;
            const pct = (c / n) * 100;
            const barW = Math.min((pct / 20) * 100, 100);
            distRows += `
                <tr>
                    <td style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.9rem;color:${p <= 4 ? 'var(--sixers-blue)' : 'var(--ink)'}">#${p}</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:8px;">
                            <div style="width:100px;height:6px;background:#e8e4dc;border-radius:3px;overflow:hidden;">
                                <div style="width:${barW}%;height:100%;background:${p <= 4 ? 'var(--sixers-blue)' : 'var(--mid)'};border-radius:3px;"></div>
                            </div>
                            <span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.85rem;">${pct.toFixed(1)}%</span>
                        </div>
                    </td>
                    <td style="color:var(--mid);font-size:0.78rem;">${c.toLocaleString()}/${n.toLocaleString()}</td>
                </tr>`;
        }

        tableWrap.innerHTML = `
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--mid);margin-bottom:0.6rem;">Sixers Pick Distribution</div>
            <table class="lottery-table">
                <thead><tr><th>Pick</th><th>Frequency</th><th>Count</th></tr></thead>
                <tbody>${distRows}</tbody>
            </table>`;
    } else {
        statsGrid.innerHTML = `<div style="color:var(--mid);font-size:0.85rem;grid-column:1/-1;text-align:center;padding:1rem;">Sixers not in lottery this year.</div>`;
        tableWrap.innerHTML = '';
    }

    massCard.style.display = 'block';
    massCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    btn.disabled = false;
    btn.textContent = 'Sim 1,000×';
}

// ─── HISTORY ────────────────────────────────────────────────────────────────
function addHistory(pickNum) {
    const now = new Date();
    const timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    simHistory.unshift({ pick: pickNum, time: timeStr });
    if (simHistory.length > 10) simHistory.pop();
    renderHistory();
}

function renderHistory() {
    const el = document.getElementById('history-list');
    if (simHistory.length === 0) {
        el.innerHTML = `<div style="text-align:center;padding:1.5rem 0;color:var(--mid);font-size:0.8rem;">Run a simulation to see results here.</div>`;
        return;
    }
    el.innerHTML = simHistory.map(h => `
        <div class="history-item">
            <div style="display:flex;align-items:center;gap:0.5rem;">
                <span class="history-pick-num${h.pick <= 4 ? ' top' : ''}">#${h.pick}</span>
                <span style="font-size:0.78rem;color:var(--mid);">${h.pick <= 4 ? '✅ Top 4' : '—'}</span>
            </div>
            <span style="font-size:0.7rem;color:var(--mid);">${h.time}</span>
        </div>`).join('');
}

function updateHistoryBadge() {
    document.getElementById('history-count-badge').textContent = `${simHistory.length} draw${simHistory.length !== 1 ? 's' : ''}`;
}

// ─── CONFETTI ────────────────────────────────────────────────────────────────
function fireConfetti() {
    const colors = ['#006BB6', '#ED174C', '#ffffff', '#4da8ff', '#ffd700'];
    for (let i = 0; i < 60; i++) {
        const el = document.createElement('div');
        el.className = 'confetti-piece';
        el.style.cssText = `
            left: ${Math.random() * 100}vw;
            background: ${colors[Math.floor(Math.random() * colors.length)]};
            width: ${4 + Math.random() * 8}px;
            height: ${4 + Math.random() * 8}px;
            border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
            animation-duration: ${1.5 + Math.random() * 2}s;
            animation-delay: ${Math.random() * 0.5}s;`;
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 4000);
    }
}

// ─── UTILS ──────────────────────────────────────────────────────────────────
function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

// ─── INIT ────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    fetchAndBuildLottery();
    // Auto-refresh daily (every 24h)
    setInterval(fetchAndBuildLottery, 24 * 60 * 60 * 1000);
});
</script>

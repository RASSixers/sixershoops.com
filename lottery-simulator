                    <div id="sixers-odds-display" style="text-align:center;padding:1.25rem 0;">
                        <div class="loading-pulse" style="width:60%;margin:0 auto 8px;"></div>
                        <div class="loading-pulse" style="width:40%;margin:0 auto;height:28px;border-radius:8px;"></div>

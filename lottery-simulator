<body>
<div class="min-h-screen">
<main>

<!-- HERO -->
<header class="hero">
    <div class="hero-glow-blue"></div>
    <div class="hero-glow-red"></div>
    <div class="hero-inner">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0;width:100%;">
            <p class="hero-title-top">Lottery</p>
            <p class="hero-title-bottom">Simulator</p>
            <div class="hero-divider"></div>
            <p class="hero-sub">Live odds based on current standings. Run simulations to see where the Sixers could land in the draft.</p>
        </div>
    </div>
</header>

<!-- MAIN CONTENT -->
<section class="main-layout">

    <!-- LEFT: Simulator -->
    <div>
        <div class="section-label">Draft Lottery Simulator</div>

        <!-- Odds Table Card -->
        <div class="card" style="margin-bottom:1.25rem;">
            <div class="card-header">
                <span class="card-title">2025 Lottery Odds</span>
                <span class="badge badge-blue" id="odds-updated-badge">Loading...</span>
            </div>
            <div id="odds-table-wrap">
                <!-- skeleton -->
                <div style="padding:1rem 1.5rem;">
                    <div class="loading-pulse" style="margin-bottom:10px;width:100%"></div>
                    <div class="loading-pulse" style="margin-bottom:10px;width:90%"></div>
                    <div class="loading-pulse" style="margin-bottom:10px;width:95%"></div>
                    <div class="loading-pulse" style="margin-bottom:10px;width:85%"></div>
                    <div class="loading-pulse" style="width:92%"></div>
                </div>
            </div>
        </div>

        <!-- Run Simulator Card -->
        <div class="card" style="margin-bottom:1.25rem;">
            <div class="card-header">
                <span class="card-title">Run Simulation</span>
                <div style="display:flex;gap:0.5rem;align-items:center;">
                    <button class="btn-secondary" id="reset-btn" style="display:none;" onclick="resetSim()">Reset</button>
                    <button class="btn-secondary" id="sim-1000-btn" onclick="runMassSimulation(1000)">Sim 1,000×</button>
                </div>
            </div>
            <div class="card-body">
                <button class="btn-run" id="run-btn" onclick="runLottery()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
                    Draw Lottery
                </button>
            </div>
        </div>

        <!-- Results Card -->
        <div class="card" id="results-card" style="display:none;">
            <div class="card-header">
                <span class="card-title">Lottery Results</span>
                <span class="badge badge-green" id="result-sixers-badge" style="display:none;">Sixers Result</span>
            </div>
            <div class="card-body">
                <div id="spinner-wrap" class="spinner-wrap" style="display:none;">
                    <div class="lottery-drum"></div>
                    <div class="spinner-text">Drawing picks...</div>
                </div>
                <div id="result-picks" class="result-picks"></div>
            </div>
        </div>

        <!-- Mass Simulation Results -->
        <div class="card" id="mass-results-card" style="display:none; margin-top:1.25rem;">
            <div class="card-header">
                <span class="card-title">Sixers in <span id="mass-sim-n">1,000</span> Simulations</span>
                <span class="badge badge-blue" id="mass-sim-badge"></span>
            </div>
            <div class="card-body">
                <div class="sim-count-grid" id="sim-stats-grid"></div>
                <div id="mass-result-table-wrap"></div>
            </div>
        </div>
    </div>

    <!-- RIGHT: Sidebar -->
